---
import Base from '@/layouts/Base.astro'
import { createReader } from '@keystatic/core/reader'
import keystaticConfig from '../../../keystatic.config'

const reader = createReader(process.cwd(), keystaticConfig)
const allWorks = await reader.collections.works.all()

const works = allWorks
  .filter((w) => w.entry.status === 'published')
  .sort((a, b) => {
    const da = a.entry.publishedAt ? new Date(a.entry.publishedAt).getTime() : 0
    const db = b.entry.publishedAt ? new Date(b.entry.publishedAt).getTime() : 0
    return db - da
  })
---

<Base title="Works" description="Portfolio and case studies.">
  <div class="container mx-auto max-w-6xl px-4 py-12">
    <h1 class="text-3xl font-semibold tracking-tight mb-8">Works</h1>

    {works.length === 0 ? (
      <p class="text-muted-foreground">暂无作品</p>
    ) : (
      <div class="grid gap-8 md:grid-cols-2">
        {works.map((work) => (
          <article class="border border-border rounded-xl overflow-hidden">
            {work.entry.coverImage && (
              <img src={work.entry.coverImage} alt="" class="w-full aspect-[16/9] object-cover" />
            )}
            <div class="p-5 flex flex-col gap-2">
              <h3 class="text-base font-semibold">{work.entry.title}</h3>
              {work.entry.summary && (
                <p class="text-muted-foreground text-sm">{work.entry.summary}</p>
              )}
              <div class="flex gap-3 mt-2">
                <a href={`/works/${work.slug}`} class="text-sm font-medium hover:underline">详情 →</a>
                {work.entry.externalUrl && (
                  <a href={work.entry.externalUrl} target="_blank" rel="noreferrer" class="text-sm text-muted-foreground hover:underline">访问 ↗</a>
                )}
              </div>
            </div>
          </article>
        ))}
      </div>
    )}
  </div>
</Base>

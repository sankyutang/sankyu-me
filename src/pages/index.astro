---
import Base from '@/layouts/Base.astro'
import { createReader } from '@keystatic/core/reader'
import keystaticConfig from '../../keystatic.config'

const reader = createReader(process.cwd(), keystaticConfig)

let settings: any = null
try {
  settings = await reader.singletons.siteSettings.read()
} catch {}

const headline = settings?.introHeadline || 'Hi, I\'m Sankyu'
const body = settings?.introBody || 'Systems, AI workflows, indie building, and products.'
---

<Base isHome title="">
  <div class="mx-auto max-w-6xl px-4 md:px-[60px]">
    <section class="py-10 md:py-12">
      <div class="flex max-w-3xl flex-col items-start gap-5 text-left">
        <h1 class="text-muted-foreground w-full text-base font-medium leading-7">
          <span class="block">{headline}</span>
          {body && <span class="mt-3 block">{body}</span>}
        </h1>
      </div>
    </section>
  </div>
</Base>

---
import Base from '@/layouts/Base.astro'
import { createReader } from '@keystatic/core/reader'
import keystaticConfig from '../../keystatic.config'

const reader = createReader(process.cwd(), keystaticConfig)

let page: any = null
try {
  page = await reader.collections.pages.read('uses')
} catch {}

const content = page ? await page.content() : null
---

<Base title="Uses" description={page?.seoDescription || 'Tools and setup I use.'}>
  <div class="container mx-auto max-w-3xl px-4 py-12">
    <h1 class="text-3xl font-semibold tracking-tight mb-8">Uses</h1>
    {content ? (
      <div class="prose prose-neutral max-w-none dark:prose-invert" set:html={content} />
    ) : (
      <p class="text-muted-foreground">内容即将更新</p>
    )}
  </div>
</Base>

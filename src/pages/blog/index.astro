---
import Base from '@/layouts/Base.astro'
import { createReader } from '@keystatic/core/reader'
import keystaticConfig from '../../../keystatic.config'

const reader = createReader(process.cwd(), keystaticConfig)
const allPosts = await reader.collections.posts.all()

const posts = allPosts
  .filter((p) => p.entry.status === 'published')
  .sort((a, b) => {
    const da = a.entry.publishedAt ? new Date(a.entry.publishedAt).getTime() : 0
    const db = b.entry.publishedAt ? new Date(b.entry.publishedAt).getTime() : 0
    return db - da
  })
---

<Base title="Blog" description="Articles about systems, AI, and indie building.">
  <div class="container mx-auto max-w-6xl px-4 py-12">
    <h1 class="text-3xl font-semibold tracking-tight mb-8">Blog</h1>

    {posts.length === 0 ? (
      <p class="text-muted-foreground">暂无文章</p>
    ) : (
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => {
          const date = post.entry.publishedAt
            ? new Date(post.entry.publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })
            : null
          return (
            <article class="flex flex-col">
              {post.entry.coverImage && (
                <a href={`/blog/${post.slug}`} class="bg-muted relative block aspect-[16/9] w-full overflow-hidden rounded-xl">
                  <img src={post.entry.coverImage} alt="" class="size-full object-cover transition-transform hover:scale-[1.02]" />
                </a>
              )}
              <div class="mt-4 flex flex-1 flex-col gap-2">
                <div class="text-muted-foreground flex flex-wrap gap-x-2 gap-y-1 text-xs">
                  {post.entry.category && <span>{post.entry.category}</span>}
                  {date && <span>{date}</span>}
                  {post.entry.readingTime != null && <span>{post.entry.readingTime} min read</span>}
                </div>
                <a href={`/blog/${post.slug}`} class="group">
                  <h3 class="text-foreground text-base font-semibold leading-snug tracking-tight group-hover:underline">
                    {post.entry.title}
                  </h3>
                </a>
                {post.entry.excerpt && (
                  <p class="text-muted-foreground line-clamp-3 text-sm leading-relaxed">{post.entry.excerpt}</p>
                )}
                <a href={`/blog/${post.slug}`} class="text-foreground mt-auto inline-flex text-sm font-medium hover:underline">
                  阅读全文 →
                </a>
              </div>
            </article>
          )
        })}
      </div>
    )}
  </div>
</Base>

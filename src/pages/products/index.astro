---
import Base from '@/layouts/Base.astro'
import { createReader } from '@keystatic/core/reader'
import keystaticConfig from '../../../keystatic.config'

const reader = createReader(process.cwd(), keystaticConfig)
const allProducts = await reader.collections.products.all()

const products = allProducts.filter((p) => p.entry.status === 'active')
---

<Base title="Products" description="Digital products and templates.">
  <div class="container mx-auto max-w-6xl px-4 py-12">
    <h1 class="text-3xl font-semibold tracking-tight mb-8">Products</h1>

    {products.length === 0 ? (
      <p class="text-muted-foreground">暂无产品</p>
    ) : (
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {products.map((product) => (
          <article class="border border-border rounded-xl p-5 flex flex-col gap-3">
            {product.entry.coverImage && (
              <img src={product.entry.coverImage} alt="" class="w-full rounded-lg aspect-[16/9] object-cover" />
            )}
            <h3 class="text-base font-semibold">{product.entry.name}</h3>
            {product.entry.summary && (
              <p class="text-muted-foreground text-sm line-clamp-2">{product.entry.summary}</p>
            )}
            <div class="mt-auto flex items-center justify-between pt-2">
              {product.entry.priceText && <span class="text-sm font-medium">{product.entry.priceText}</span>}
              {product.entry.externalUrl && (
                <a href={product.entry.externalUrl} target="_blank" rel="noreferrer" class="text-sm font-medium hover:underline">
                  {product.entry.ctaText || 'Get it'} →
                </a>
              )}
            </div>
          </article>
        ))}
      </div>
    )}
  </div>
</Base>

---

<button
  id="theme-toggle"
  class="hover:bg-muted inline-flex size-9 items-center justify-center rounded-lg transition-colors"
  aria-label="Toggle theme"
>
  <svg id="sun-icon" class="size-4 hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <circle cx="12" cy="12" r="5" />
    <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" />
  </svg>
  <svg id="moon-icon" class="size-4 hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" />
  </svg>
</button>

<script>
  function updateIcons() {
    const isDark = document.documentElement.classList.contains('dark')
    document.getElementById('sun-icon')?.classList.toggle('hidden', !isDark)
    document.getElementById('moon-icon')?.classList.toggle('hidden', isDark)
  }

  updateIcons()

  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.contains('dark')
    document.documentElement.classList.toggle('dark', !isDark)
    localStorage.setItem('theme', isDark ? 'light' : 'dark')
    updateIcons()
  })
</script>

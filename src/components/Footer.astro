---
import { defaultMainNav } from '@/lib/nav'
import ThemeToggle from '@/components/ThemeToggle.astro'

interface Props {
  siteName: string
  isHome?: boolean
}

const { siteName, isHome = false } = Astro.props
const year = new Date().getFullYear()
---

{isHome ? (
  <footer class="border-border mt-24 border-t">
    <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-10 md:px-[60px]">
      <p class="text-muted-foreground text-xs">{siteName} © {year}</p>
      <ThemeToggle />
    </div>
  </footer>
) : (
  <footer class="border-border mt-24 border-t">
    <div class="container mx-auto max-w-6xl px-4 py-12">
      <div class="flex flex-col gap-8 md:flex-row md:justify-between">
        <div>
          <p class="font-semibold">{siteName}</p>
          <p class="text-muted-foreground mt-2 max-w-sm text-sm">
            One-person company, systems, and leverage — built in public.
          </p>
        </div>
      </div>
      <hr class="my-8 border-border" />
      <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
        <nav class="flex flex-wrap gap-x-4 gap-y-2 text-sm">
          {defaultMainNav.map((item) => (
            <a href={item.href} class="text-muted-foreground hover:text-foreground">{item.label}</a>
          ))}
        </nav>
        <p class="text-muted-foreground text-xs">© {year} {siteName}</p>
      </div>
    </div>
  </footer>
)}
